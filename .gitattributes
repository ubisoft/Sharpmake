# Set the default behavior, in case people don't have core.autocrlf set.
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.cs text
*.py text
*.md text
*.txt text
*.yml text
*.reg text

# Declare files that will always have CRLF line endings on checkout.
*.sln text eol=crlf
*.bat text eof=crlf
*.reg text eof=crlf
*.csproj text eof=crlf

# Declare files that must keep lf
*.sh text eol=lf
# Template files with embedded newlines must stay LF so public API snapshots are consistent across platforms
Sharpmake.Generators/FastBuild/Bff.Template.cs text eol=lf

# Verify snapshot files
*.verified.txt text eol=lf working-tree-encoding=UTF-8